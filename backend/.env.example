# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_copytrading

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Zeabur (for agent provisioning)
ZEABUR_API_TOKEN=your-zeabur-api-token
ZEABUR_PROJECT_ID=your-zeabur-project-id

# Redis
REDIS_URL=redis://localhost:6379

# Backend URL (for signal tracker heartbeat)
BACKEND_URL=http://localhost:3000
